{% extends 'base.html.twig' %}

{% block title %}Hello PackageController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        <h1>Package Table</h1>
        <a href="{{ path('app_package_new') }}"> Create New Package</a>
        <br>
        <table>
            <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Description</th>
                <th>Price</th>
                <th>Photo</th>
                <th>Created At</th>
                <th>Category</th>
                <th>Business</th>
            </tr>
            </thead>
            <tbody>
            {% for package in packages %}
                <tr>
                    <td>
                        <a href="{{ path("app_package_view", {
                            "id": package.id}) }}">
                            {{ package.id }}
                        </a>
                    </td>
                    <td>
                        {{ package.name }}
                    </td>
                    <td>
                        {{ package.description }}
                    </td>
                    <td>
                        {{ package.price }}
                    </td>
                    <td>
                        {% if package.photo %}
                            {{ package.photo }}
                        {% else %}
                            No photo
                        {% endif %}
                    </td>
                    <td>
                        {{ package.createdAt|date('Y-m-d H:i:s') }}
                    </td>
                    <td>
                        {{ package.category.name }}
                    </td>
                    <td>
                        {{ package.business.name }}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
