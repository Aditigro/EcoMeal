{% extends 'base.html.twig' %}

{% block title %}Hello PackageController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }

        .card {
            transition: transform 0.1s;
        }

        .card:hover {
            transform: translate(0, -3px) scale(1.05);
        }

        a {
            text-decoration: none;
            color: inherit;
        }
    </style>

    <div class="example-wrapper">
        <h1 class="text-center">Package</h1>
        {% if is_granted('ROLE_BUSINESS') %}
            <p class="text-center py-1"><em> To create a new package, access the view page of a
                    <a href="{{ path('app_business') }}">business</a>.</em></p>
        {% endif %}
        <p>
            {{ form_start(form) }}
            {{ form_end(form) }}
        </p>
        <div class="d-flex justify-content-center">
            <div class="container">
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    {% for package in packages %}
                        {% include 'package/card.html.twig' %}
                    {% else %}
                        <p class="alert alert-warning"> No packages found</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
