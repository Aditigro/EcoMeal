{% extends 'base.html.twig' %}

{% block title %}Hello BusinessController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        <h1>Consumer View</h1>
        <p> Id: {{ consumer.id }}</p>
        <p> First Name: {{ consumer.firstName }}</p>
        <p> Last Name: {{ consumer.lastName }}</p>
        <p> Phone: {{ consumer.phoneNumber }}</p>
        <br>
        <h2>Orders:</h2>
        <table>
            <thead>
            <tr>
                <th>Id</th>
                <th>Created At</th>
                <th>Package</th>
            </tr>
            </thead>
            <tbody>
            {% for order in consumer.orders %}
                <tr>
                    <td>
                        {{ order.id }}
                    </td>
                    <td>
                        {{ order.createdAt|date('Y-m-d H:i:s') }}
                    </td>
                    <td>
                        {{ order.package.name }}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        <br>
        <p>
            <a href="{{ path("app_order_new", {
                "id": consumer.id
            }) }}">
                Create a new order for {{ consumer.firstName}} {{ consumer.lastName}}
            </a>
        </p>
        <p>
            <a href="{{ path("app_consumer_update", {
                "id": consumer.id}) }}">
                Update
            </a>
        </p>
        <p>
            <a href="{{ path("app_consumer") }}"> Back </a>
        </p>
    </div>
{% endblock %}
