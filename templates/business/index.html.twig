{% extends 'base.html.twig' %}

{% block title %}Hello BusinessController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        <h1>Business Table</h1>
        <a href="{{ path('app_business_new') }}"> Create New Business</a>
        <br>
        <table>
            <thead>
            <tr>
                <th>Actions</th>
                <th>Id</th>
                <th>Name</th>
                <th>City</th>
                <th>Street</th>
                <th>House Number</th>
                <th>Phone Number</th>
                <th>Business Type</th>
            </tr>
            </thead>
            <tbody>
            {% for business in businesses %}
                <tr>
                    <td>
                        <p><a href="{{ path("app_business_view", {
                                "id": business.id}) }}">
                                View
                            </a></p>
                        <p><a href="{{ path("app_business_update", {
                                "id": business.id}) }}">
                                Update
                            </a></p>
                        <p>
                        <form action="{{ path('app_business_delete',{
                            "id": business.id}
                        ) }}" method="post">
                            <button type="submit">Delete</button>
                        </form>
                        </p>
                    </td>
                    <td>
                        {{ business.id }}
                    </td>
                    <td>
                        {{ business.name }}
                    </td>
                    <td>
                        {{ business.city }}
                    </td>
                    <td>
                        {{ business.street }}
                    </td>
                    <td>
                        {{ business.houseNumber }}
                    </td>
                    <td>
                        {{ business.phoneNumber }}
                    </td>
                    <td>
                        {{ business.businessType.name }}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
