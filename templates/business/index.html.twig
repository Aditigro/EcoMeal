{% extends 'base.html.twig' %}

{% block title %}Hello BusinessController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        <h1 class="text-center">Business</h1>
        <a class="btn btn-primary position-absolute start-50 translate-middle-x" href="{{ path('app_business_new') }}"> Create New Business</a>
        <br>
        <br>
        <div class="d-flex justify-content-center">
            <table class="table table-striped">
                <thead>
                <tr class="table-primary">
                    <th class="text-center px-3">Actions</th>
                    <th class="text-center px-3">Id</th>
                    <th class="text-center px-3">Name</th>
                    <th class="text-center px-3">City</th>
                    <th class="text-center px-3">Street</th>
                    <th class="text-center px-3">House Number</th>
                    <th class="text-center px-3">Phone Number</th>
                    <th class="text-center px-3">Business Type</th>
                </tr>
                </thead>
                <tbody>
                {% for business in businesses %}
                    <tr class="table-secondary">
                        <td class="align-middle px-3">
                            <form action="{{ path('app_business_delete',{
                                "id": business.id}
                            ) }}" method="post">
                                <div class="btn-group">
                                    <a class="btn btn-primary" href="{{ path("app_business_update", {
                                        "id": business.id}) }}">
                                        Update
                                    </a>
                                    <a class="btn btn-secondary" href="{{ path("app_business_view", {
                                        "id": business.id}) }}">
                                        View
                                    </a>
                                    <button class="btn btn-danger" type="submit">Delete</button>
                                </div>
                            </form>
                        </td>
                        <td class="text-center px-3 align-middle">
                            {{ business.id }}
                        </td>
                        <td class="text-center px-3 text-nowrap align-middle">
                            {{ business.name }}
                        </td>
                        <td class="text-center px-3 align-middle">
                            {{ business.city }}
                        </td>
                        <td class="text-center px-3 align-middle">
                            {{ business.street }}
                        </td>
                        <td class="text-center px-3 align-middle">
                            {{ business.houseNumber }}
                        </td>
                        <td class="text-center px-3 align-middle">
                            {{ business.phoneNumber }}
                        </td>
                        <td class="text-center px-3 align-middle">
                            {{ business.businessType.name }}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

    </div>
{% endblock %}
