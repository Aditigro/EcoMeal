{% extends 'base.html.twig' %}

{% block title %}Hello PackageController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        <h1>Create a new Order for {{ consumer.firstName }} {{ consumer.lastName }}</h1>
        {{ form_start(form) }}
            {{ form_row(form.package) }}
            {{ form_row(form.submit) }}
        {{ form_end(form) }}
        <br>
        <a href="{{ path('app_consumer_view', {
            "id": consumer.id
        }) }}">Back</a>

    </div>
{% endblock %}
