{% extends 'base.html.twig' %}

{% block title %}Hello OrderController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        <h1>Order Table</h1>
        <br>
        <table>
            <thead>
            <tr>
                <th>Actions</th>
                <th>Id</th>
                <th>Created At</th>
                <th>Package</th>
                <th>Consumer</th>
            </tr>
            </thead>
            <tbody>
            {% for order in orders %}
                <tr>
                    <td>
                        <p><a href="{{ path("app_order_view", {
                                "id": order.id}) }}">
                                View
                            </a></p>
                        <p><a href="{{ path("app_order_update", {
                                "id": order.id}) }}">
                                Update
                            </a></p>
                        <p>
                        <form action="{{ path('app_order_delete',{
                            "id": order.id}
                        ) }}" method="post">
                            <button type="submit">Delete</button>
                        </form>
                    </td>
                    <td>
                        {{ order.id }}
                    </td>
                    <td>
                        {{ order.createdAt|date('Y-m-d H:i:s') }}
                    </td>
                    <td>
                        {{ order.package.name }}
                    </td>
                    <td>
                        {{ order.consumer.firstName }} {{ order.consumer.lastName }}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
