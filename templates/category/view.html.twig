{% extends 'base.html.twig' %}

{% block title %}Hello CategoryController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        <h1 class="text-center">{{ category.name }}</h1>
        <p class="text-center py-1">Id: {{ category.id }}</p>
        <div class="text-center">
            <form action="{{ path('app_category_delete',{
                "id": category.id}
            ) }}" method="post">
                <div class="btn-group">
                    <a class="btn btn-primary" href="{{ path("app_category_update", {
                        "id": category.id}) }}">
                        Update
                    </a>
                    <a class="btn btn-secondary" href="{{ path("app_category") }}">
                        Back
                    </a>
                    <button class="btn btn-danger" type="submit">Delete</button>
                </div>
            </form>
        </div>
    </div>
{% endblock %}
