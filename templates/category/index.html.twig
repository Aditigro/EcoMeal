{% extends 'base.html.twig' %}

{% block title %}Hello CategoryController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        <h1 class="text-center">Category</h1>
        <a class="btn btn-primary position-absolute start-50 translate-middle-x" href="{{ path('app_category_new') }}"> Create New Category</a>
        <br>
        <br>
        <div class="d-flex justify-content-center">
            <table class="table table-striped">
                <thead>
                <tr class="table-primary">
                    <th class="text-center px-3">Actions</th>
                    <th class="text-center px-3">Id</th>
                    <th class="text-center px-3">Name</th>
                </tr>
                </thead>
                <tbody>
                {% for category in categories %}
                    <tr class="table-secondary">
                        <td class="align-middle text-center">
                            <form action="{{ path('app_category_delete',{
                                "id": category.id}
                            ) }}" method="post">
                                <div class="btn-group">
                                    <a class="btn btn-primary" href="{{ path("app_category_update", {
                                        "id": category.id}) }}">
                                        Update
                                    </a>
                                    <a class="btn btn-secondary" href="{{ path("app_category_view", {
                                        "id": category.id}) }}">
                                        View
                                    </a>
                                    <button class="btn btn-danger" type="submit">Delete</button>
                                </div>
                            </form>
                        </td>
                        <td class="text-center px-3 align-middle">
                            {{ category.id }}
                        </td>
                        <td class="text-center px-3 align-middle">
                            {{ category.name }}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

    </div>
{% endblock %}
