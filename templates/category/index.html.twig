{% extends 'base.html.twig' %}

{% block title %}Hello CategoryController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        <h1>Category Table</h1>
        <a href="{{ path('app_category_new') }}"> Create New Category</a>
        <br>
        <table>
            <thead>
            <tr>
                <th>Actions</th>
                <th>Id</th>
                <th>Name</th>
            </tr>
            </thead>
            <tbody>
            {% for category in categories %}
                <tr>
                    <td>
                        <p><a href="{{ path("app_category_view", {
                                "id": category.id}) }}">
                                View
                            </a></p>
                        <p><a href="{{ path("app_category_update", {
                                "id": category.id}) }}">
                                Update
                            </a></p>
                        <p>
                        <form action="{{ path('app_category_delete',{
                            "id": category.id}
                        ) }}" method="post">
                            <button type="submit">Delete</button>
                        </form>
                    </td>
                    <td>
                        {{ category.id }}
                    </td>
                    <td>
                        {{ category.name }}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
